---
import { Image } from 'astro:assets';

// Cuando subas tus imágenes a src/assets, puedes importarlas así:
// import envelopeBg from '../assets/envelope-bg.jpg';
// import flowerImg from '../assets/flower.png';
// import fotoNovios from '../assets/foto-novios.jpg';
---

<section class="flex flex-col w-full bg-[#750b1c] overflow-hidden">
  
  <div class="relative w-full flex flex-col items-center">
    
    {/* PARTE 1: Fondo verde con el sobre (hero.webp) */}
    <div class="w-full h-[60vh] md:h-[70vh] relative overflow-hidden bg-[#3a4f3b]">
      <img src="/hero.webp" alt="Fondo Verde Sobre" class="w-full h-full object-cover object-bottom opacity-100 animate-slow-zoom origin-center" onerror="this.style.display='none'" loading="eager" fetchpriority="high" />
      {/* Gradiente oscuro sutil para darle profundidad */}
      <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/40 mix-blend-overlay"></div>
    </div>

    {/* PARTE 2: Flor y Detalles de Fecha/Lugar */}
    <div class="w-full relative flex flex-col items-center bg-[#750b1c]">
      {/* Imagen de la Flor */}
      <img src="/flor.webp" alt="Flor" class="w-full object-cover" onerror="this.style.display='none'" loading="eager" />

      {/* Texto Detalles superpuesto en la flor */}
      <div class="absolute bottom-12 md:bottom-20 z-10 text-center space-y-4 md:space-y-6 text-brand-ivory w-full px-4">
        <p class="font-serif tracking-[0.4em] text-sm md:text-base uppercase" data-scroll-fade>Viernes 11</p>
        <p class="font-sans tracking-[0.2em] text-sm font-light" data-scroll-fade>2 : 0 0 P M</p>
        <p class="font-serif tracking-[0.3em] text-xs md:text-sm uppercase leading-loose" data-scroll-fade>
          Hacienda San Pablo<br/>
          <span class="text-[10px] md:text-xs tracking-[0.4em]">Subachoque . Colombia</span>
        </p>
      </div>
    </div>

    {/* PARTE 3: Tarjeta Blanca ("Save our Date") - Flotando entre ambas secciones */}
    <div class="absolute top-[25vh] md:top-[30vh] left-0 w-full flex justify-center z-10">
      <div class="w-[85%] max-w-sm aspect-[3/4] p-10 flex flex-col items-center justify-between shadow-luxury rounded-sm overflow-hidden bg-[#faf8f5] animate-float">
        {/* Textura de la tarjeta */}
        <div class="absolute inset-0 z-0 bg-[#faf8f5]">
           <img src="/sobre.webp" alt="Textura Tarjeta" class="w-full h-full object-cover opacity-80" onerror="this.style.display='none'" loading="eager" fetchpriority="high" />
           <div class="absolute inset-0 bg-gradient-to-tr from-[#faf8f5]/80 via-[#faf8f5]/40 to-[#faf8f5]/90"></div> 
        </div>

        <div class="relative z-10 flex flex-col items-center h-full justify-between w-full">
          <p class="font-serif tracking-[0.4em] text-[#5e0a16] text-sm mt-4 font-semibold animate-fade-up delay-100">S & D</p>
          
          <div class="text-center flex flex-col items-center justify-center w-full my-4 animate-fade-up delay-300">
            <img 
              src="/save-our-date.webp" 
              alt="Save our Date" 
              class="w-full max-w-[200px] md:max-w-[260px] h-auto object-contain" 
              onerror="this.style.display='none'"
              loading="eager"
              fetchpriority="high"
            />
          </div>

          <p class="font-serif tracking-[0.4em] text-[#5e0a16] text-sm mb-4 font-semibold animate-fade-up delay-700">
            11 . 12 . 26
          </p>
        </div>
      </div>
    </div>

  </div>

  {/* PARTE 3: Foto de los Novios */}
  <div class="w-full h-[60vh] md:h-[80vh] relative bg-black">
    <img 
      src="/fotonovios1.webp" 
      alt="Sebastián y Daniela" 
      class="w-full h-full object-cover object-center opacity-90"
      loading="eager"
      fetchpriority="high"
    />
    
    {/* Difuminado superior extracorto con el color exacto de la flor (#670e01) */}
    <div class="absolute top-0 left-0 w-full h-8 md:h-12 bg-gradient-to-b from-[#670e01] to-transparent z-10 pointer-events-none"></div>

    {/* Difuminado inferior corto (Solo debajo de las letras) */}
    <div class="absolute bottom-0 left-0 w-full h-32 md:h-40 bg-gradient-to-t from-black/90 via-black/40 to-transparent z-10 pointer-events-none"></div>
    
    {/* Nombres sobre la foto */}
    <div class="absolute bottom-10 left-0 w-full flex justify-center z-20 px-4 pointer-events-none">
      <div class="w-[85%] max-w-[350px] md:max-w-[450px] flex justify-center drop-shadow-letter-premium">
         <img 
            src="/sebasdani.webp" 
            alt="Sebastián y Daniela" 
            class="w-full h-auto object-contain"
            loading="eager"
            data-scroll-fade
         />
      </div>
    </div>
  </div>



</section>

<script>
  // Animación puramente ligada al Scroll (Parallax Fade)
  document.addEventListener('DOMContentLoaded', () => {
    const animatedElements = document.querySelectorAll('[data-scroll-fade]');
    
    const updateScrollAnimations = () => {
      const windowHeight = window.innerHeight;
      
      animatedElements.forEach(el => {
        const rect = el.getBoundingClientRect();
        const elementTop = rect.top;
        
        // Empieza a aparecer cuando su parte superior toca el fondo de la pantalla
        const startPoint = windowHeight; 
        // Termina de aparecer (100% visible) en cuanto entra un 10% a la pantalla
        const endPoint = windowHeight * 0.90; 
        
        let progress = (startPoint - elementTop) / (startPoint - endPoint);
        progress = Math.max(0, Math.min(1, progress)); // Limitar entre 0 y 1
        
        // Calcular valores
        const blurAmount = (1 - progress) * 12; // De 12px a 0px
        const yOffset = (1 - progress) * 30; // De 30px abajo a 0px
        
        // Aplicar directamente
        el.style.opacity = progress.toFixed(2);
        el.style.transform = `translateY(${yOffset}px)`;
        el.style.filter = `blur(${blurAmount}px)`;
      });
    };

    // Ejecutar al inicio y cada vez que hagan scroll
    window.addEventListener('scroll', updateScrollAnimations, { passive: true });
    window.addEventListener('resize', updateScrollAnimations, { passive: true });
    updateScrollAnimations();
  });
</script>
