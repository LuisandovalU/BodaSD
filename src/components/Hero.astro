---
// src/components/Hero.astro
---

<section class="relative min-h-screen flex flex-col items-center justify-between pb-20 overflow-hidden bg-brand-wine">
  <!-- Background Image with Gradient Fade -->
  <div class="absolute inset-0 z-0 h-[70vh] md:h-[80vh]">
    <img 
      src="https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=2000&auto=format&fit=crop" 
      alt="Sebastián y Daniela" 
      class="w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-brand-wine"></div>
  </div>

  <!-- Top Content (Names) -->
  <div class="z-10 text-center text-white px-4 pt-24 md:pt-32 w-full">
    <div class="inline-block px-8 py-10 bg-white/5 backdrop-blur-sm border border-white/10 shadow-2xl rounded-sm">
      <p class="font-serif tracking-[0.3em] text-sm uppercase mb-6 text-brand-gold-light">S & D</p>
      <h1 class="font-script text-7xl md:text-8xl leading-tight text-white drop-shadow-md">
        Sebastián
        <br/>
        <span class="text-4xl md:text-5xl text-brand-gold-light opacity-80">&</span>
        <br/>
        Daniela
      </h1>
      <p class="mt-8 font-serif text-lg tracking-[0.2em] uppercase text-brand-gold-light">
        11 . 12 . 26
      </p>
    </div>
  </div>

  <!-- Bottom Content (Details & Welcome) -->
  <div class="z-10 text-center px-6 mt-16 md:mt-24 w-full max-w-2xl mx-auto flex flex-col items-center space-y-12">
    
    <div class="space-y-4">
      <p class="font-serif tracking-[0.2em] text-brand-gold-light uppercase text-sm md:text-base">Viernes 11</p>
      <p class="font-sans tracking-widest text-white/90 text-sm">2:00 PM</p>
      <p class="font-serif tracking-[0.15em] text-brand-gold-light uppercase text-sm md:text-base leading-relaxed">
        Hacienda San Pablo<br/>
        <span class="text-xs tracking-widest text-white/70">Subachoque . Colombia</span>
      </p>
    </div>

    <div class="bg-brand-ivory text-brand-wine p-8 md:p-12 rounded-sm shadow-xl relative w-full overflow-hidden">
      <!-- Decorative flower element (placeholder for the white anthurium) -->
      <div class="absolute -top-10 -right-10 opacity-10 pointer-events-none">
        <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-flower-2"><path d="M12 5.5c.135-1.189.655-2.288 1.488-3.12a3.53 3.53 0 0 1 5.372 4.544"/><path d="M18.86 6.924a4.42 4.42 0 0 1-.41 5.56l-6.45 6.45a2 2 0 0 1-2.828 0l-6.45-6.45a4.42 4.42 0 0 1 6.25-6.25l3.89 3.89"/><path d="M12 5.5v13"/><path d="M12 18.5c-.135 1.189-.655 2.288-1.488 3.12a3.53 3.53 0 0 1-5.372-4.544"/></svg>
      </div>
      
      <h2 class="font-serif text-2xl md:text-3xl tracking-widest text-brand-wine-dark uppercase mb-6">
        Con todo nuestro cariño
      </h2>
      <p class="font-sans text-xs md:text-sm leading-loose tracking-[0.15em] uppercase text-brand-wine/80">
        Bienvenidos al inicio de nuestra mejor aventura. Tu presencia hará que este momento sea verdaderamente inolvidable.
      </p>
    </div>

  </div>
</section>
