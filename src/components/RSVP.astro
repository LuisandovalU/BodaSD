---
// src/components/RSVP.astro
---

<section class="bg-[#f5f5f0] py-24 px-4 text-center">
  <div class="max-w-2xl mx-auto space-y-12">
    
    <div class="space-y-4">
      <div class="flex justify-center mb-6">
        <img src="/confirma.webp" alt="Confirmación de Asistencia" class="w-[90%] max-w-[400px] md:max-w-[500px] h-auto object-contain drop-shadow-sm" />
      </div>
      <p class="font-sans text-xs md:text-sm leading-loose tracking-[0.15em] uppercase text-brand-wine/80">
        Para asegurar tu lugar y celebrar juntos este día tan especial, te pedimos amablemente confirmar tu asistencia realizando el pago de:
      </p>
      <p class="font-serif text-2xl tracking-[0.2em] text-brand-wine-dark mt-6 font-semibold">
        $300 MXN
      </p>
      <p class="font-sans text-[10px] md:text-xs tracking-widest uppercase text-brand-wine/60 mt-2">
        A más tardar el [Día y Mes Límite]
      </p>
      <p class="font-sans text-xs leading-loose tracking-[0.1em] uppercase text-brand-wine/80 mt-8 max-w-md mx-auto border-t border-brand-wine/10 pt-6">
        Comparte tu comprobante de pago con nosotros para que tu lugar quede oficialmente registrado.
      </p>
    </div>

    {/* RSVP Form to WhatsApp */}
    <div class="bg-white p-8 md:p-12 shadow-xl border border-gray-100 rounded-sm mt-12 relative overflow-hidden group">
      <div class="absolute inset-0 bg-brand-wine opacity-0 group-hover:opacity-5 transition-opacity duration-500 pointer-events-none"></div>
      
      <form id="rsvp-form" class="space-y-6 max-w-sm mx-auto relative z-10 text-left">
        <div class="space-y-2">
          <label for="name" class="block font-serif text-sm tracking-widest text-brand-wine uppercase">Nombre Completo</label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            required 
            placeholder="Ej. Juan Pérez"
            class="w-full bg-gray-50 border border-gray-200 text-brand-wine text-sm rounded-none focus:ring-brand-gold focus:border-brand-gold block p-3 transition-colors outline-none"
          >
        </div>
        
        <button 
          type="submit" 
          class="w-full bg-brand-wine hover:bg-brand-wine-dark text-white font-serif tracking-[0.2em] uppercase text-sm py-4 px-6 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
        >
          Enviar Comprobante
        </button>
      </form>
    </div>

    {/* Collage Fotográfico Polaroid */}
    <div class="mt-20 relative w-full max-w-lg mx-auto px-4">
      
      {/* Foto 1 - Arriba izquierda, horizontal */}
      <div class="polaroid-item group relative w-[65%] -rotate-2 mb-[-30px] z-10 transition-all duration-500 ease-out hover:scale-110 hover:-rotate-1 hover:z-40 [&.active]:scale-110 [&.active]:-rotate-1 [&.active]:z-40 cursor-pointer">
        <div class="bg-white p-2 pb-10 shadow-2xl shadow-black/20 rounded-sm">
          <div class="aspect-square overflow-hidden">
            <img src="/collage/foto1.webp" alt="Sebastián y Daniela" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 group-[.active]:scale-105" loading="lazy" />
          </div>
        </div>
      </div>

      {/* Foto 2 - Centro derecha */}
      <div class="polaroid-item group relative w-[55%] ml-auto rotate-1 mb-[-20px] z-20 transition-all duration-500 ease-out hover:scale-110 hover:rotate-0 hover:z-40 [&.active]:scale-110 [&.active]:rotate-0 [&.active]:z-40 cursor-pointer">
        <div class="bg-white p-2 pb-10 shadow-2xl shadow-black/20 rounded-sm">
          <div class="aspect-square overflow-hidden">
            <img src="/collage/foto2.webp" alt="Sebastián y Daniela" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 group-[.active]:scale-105" loading="lazy" />
          </div>
        </div>
      </div>

      {/* Foto 3 - Abajo izquierda, vertical */}
      <div class="polaroid-item group relative w-[60%] -rotate-1 mb-[-25px] z-10 transition-all duration-500 ease-out hover:scale-110 hover:rotate-0 hover:z-40 [&.active]:scale-110 [&.active]:rotate-0 [&.active]:z-40 cursor-pointer">
        <div class="bg-white p-2 pb-10 shadow-2xl shadow-black/20 rounded-sm">
          <div class="aspect-square overflow-hidden">
            <img src="/collage/foto3.webp" alt="Sebastián y Daniela" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 group-[.active]:scale-105" loading="lazy" />
          </div>
        </div>
      </div>

      {/* Foto 4 - Abajo derecha */}
      <div class="polaroid-item group relative w-[55%] ml-auto rotate-2 z-20 transition-all duration-500 ease-out hover:scale-110 hover:rotate-3 hover:z-40 [&.active]:scale-110 [&.active]:rotate-3 [&.active]:z-40 cursor-pointer">
        <div class="bg-white p-2 pb-10 shadow-2xl shadow-black/20 rounded-sm">
          <div class="aspect-square overflow-hidden">
            <img src="/collage/foto4.webp" alt="Sebastián y Daniela" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 group-[.active]:scale-105" loading="lazy" />
          </div>
        </div>
      </div>

    </div>

    {/* Firma final superpuesta */}
    <div class="relative w-full max-w-lg mx-auto px-4 mt-[-60px] md:mt-[-80px] flex flex-col items-start z-30 pointer-events-none">
      <img src="/con_amor.webp" alt="Con amor" class="w-16 md:w-20 h-auto object-contain drop-shadow-sm ml-4 mb-[-8px]" />
      <img src="/sebasdani_wine.webp" alt="Sebastián & Daniela" class="w-[90%] max-w-[340px] md:max-w-[420px] h-auto object-contain drop-shadow-xl" />
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('rsvp-form');
  // Placeholder phone number - replace with the actual number
  const phoneNumber = '520000000000'; 

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const nameInput = document.getElementById('name') as HTMLInputElement;
    const name = nameInput.value;
    
    if (name) {
      const message = encodeURIComponent(`¡Hola! Quiero confirmar mi asistencia, soy ${name}. Aquí está mi comprobante:`);
      const whatsappUrl = `https://wa.me/${phoneNumber}?text=${message}`;
      window.open(whatsappUrl, '_blank');
    }
  });
  // Animación Polaroid al hacer scroll (especial para móvil)
  const polaroids = document.querySelectorAll('.polaroid-item');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      // Se activa cuando la foto cruza el centro de la pantalla
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
      } else {
        entry.target.classList.remove('active');
      }
    });
  }, {
    rootMargin: '-35% 0px -35% 0px', // Zona central del 30% de la pantalla
    threshold: 0
  });

  polaroids.forEach(el => observer.observe(el));
</script>
