---
import ScrollEnvelope from './ScrollEnvelope';
---

<div class="flex flex-col w-full">
  
  {/* Sección Importante */}
  <section class="text-white py-24 px-4 text-center relative overflow-hidden">
    {/* Fondo rojo */}
    <div class="absolute inset-0 z-0" style="background-image: url('/fondrojo.webp'); background-size: 100% auto; background-repeat: repeat-y; background-position: top center;">
      <div class="absolute inset-0 bg-black/10"></div>
    </div>
    
    <div class="max-w-3xl mx-auto relative z-10">
      <div class="space-y-6">
        <div class="flex justify-center mb-6">
          <img src="/importante_gold.webp" alt="Importante" class="w-[90%] max-w-[320px] md:max-w-[400px] h-auto object-contain drop-shadow-sm" />
        </div>
        <p class="font-sans text-xs md:text-sm leading-loose tracking-[0.15em] uppercase opacity-90 max-w-xl mx-auto">
          Para que todos podamos disfrutar y celebrar al máximo, nuestro evento será exclusivamente para adultos. Agradecemos tu comprensión para dejar a los niños en casa.
        </p>
      </div>
    </div>
  </section>

  {/* Sección Regalos (Animación al scrollear) */}
  <ScrollEnvelope client:load />

</div>
