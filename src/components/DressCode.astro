---
import ColorPalette from './ColorPalette';

const ladiesColors = ['#f2e176', '#6b8233', '#8f623e', '#d8a7c2'];
const gentsColors = ['#0a3791', '#6b8233', '#8f623e', '#75787b'];
const bannedColors = ['#000000', '#7b1113'];
---

<section class="w-full flex flex-col bg-[#e9e9e6]">
  
  {/* TOP SECTION: Ladies */}
  <div class="relative w-full flex flex-col items-center pt-24 pb-16 px-6 text-center">
    {/* Background Ladies */}
    <div class="absolute inset-0 z-0">
      <img src="/dcarriba.webp" alt="Fondo Mujeres" class="w-full h-full object-cover" loading="lazy" />
      <div class="absolute inset-0 bg-black/20"></div>
    </div>

    <div class="relative z-10 w-full max-w-4xl mx-auto flex flex-col items-center">
      {/* Dress Code Title Image */}
      <div class="mb-12 w-full flex justify-center">
        <img src="/dc.webp" alt="Dress Code" class="w-[85%] max-w-[320px] md:max-w-[400px] h-auto object-contain drop-shadow-md" />
      </div>

      <h3 class="font-serif tracking-[0.2em] text-white text-lg md:text-xl uppercase font-bold mb-8">For the Ladies</h3>
      <p class="font-serif text-[10px] md:text-xs leading-loose tracking-[0.25em] uppercase text-white/95 max-w-md mx-auto">
        Para celebrar esta gran noche, la etiqueta es gala formal con vestido largo. Por favor, consulten en la parte de abajo la guía con los colores recomendados para su atuendo y aquellos que se deben evitar.
      </p>

      {/* Color Palette Ladies */}
      <div class="pt-10 w-full">
        <ColorPalette client:visible colors={ladiesColors} title="Colores Sugeridos" />
      </div>
    </div>
  </div>

  {/* DIVIDER: Line + Circle */}
  <div class="relative w-full h-px z-20 flex justify-center items-center">
    <div class="absolute w-full h-[1px] bg-white/20"></div>
    <div class="w-16 h-16 bg-[#f0f0f0] rounded-full z-10 relative flex items-center justify-center"></div>
  </div>

  {/* BOTTOM SECTION: Gentlemen */}
  <div class="relative w-full flex flex-col items-center pt-16 pb-24 px-6 text-center">
    {/* Background Gentlemen */}
    <div class="absolute inset-0 z-0">
      <img src="/dcabajo.webp" alt="Fondo Hombres" class="w-full h-full object-cover" loading="lazy" />
      <div class="absolute inset-0 bg-black/20"></div>
    </div>

    <div class="relative z-10 w-full max-w-4xl mx-auto flex flex-col items-center">
      <h3 class="font-serif tracking-[0.2em] text-white text-lg md:text-xl uppercase font-bold mb-8">For the Gentleman</h3>
      <p class="font-serif text-[10px] md:text-xs leading-loose tracking-[0.25em] uppercase text-white/95 max-w-md mx-auto">
        Nuestra etiqueta es gala formal. Les pedimos amablemente lucir un traje elegante, omitiendo por completo el color negro. En la parte inferior podrán encontrar nuestra guía con los tonos sugeridos y los colores que les pedimos evitar.
      </p>

      {/* Color Palette Gents */}
      <div class="pt-10 w-full">
        <ColorPalette client:visible colors={gentsColors} title="Colores Sugeridos" />
      </div>

      {/* Banned Colors */}
      <div class="pt-16 w-full">
        <ColorPalette client:visible colors={bannedColors} title="No Permitidos" isBanned={true} />
      </div>
    </div>
  </div>

</section>
